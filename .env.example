# ============================================================================
# SOC SIEM PRO — Environment Configuration Template
# ============================================================================
# Copy this file to .env and fill in your actual credentials.
# NEVER commit .env to git — add it to .gitignore
#
# The system will gracefully degrade if optional services are not configured.
# ============================================================================

# ── VirusTotal (File Hash Intelligence) ───────────────────────────────────
# Get free API key at: https://www.virustotal.com/gui/home/upload
# Free tier: 4 lookups per minute
VT_API_KEY=

# ── AbuseIPDB (IP Reputation) ─────────────────────────────────────────────
# Get free API key at: https://www.abuseipdb.com/register
# Free tier: 1000 lookups per day
ABUSEIPDB_API_KEY=

# ── Ollama (Local LLM for analysis) ───────────────────────────────────────
# Ollama must be running locally before starting the app. Install from: https://ollama.ai
# Start with: ollama serve
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=
SOC_REPORT_MODEL=
SOC_ENABLE_OLLAMA=1
SOC_ENABLE_REPORTS=1
SOC_AUTO_BLOCK_SCORE=90

# ── Sandbox Analysis (Optional) ───────────────────────────────────────────
# Cuckoo Sandbox: https://cuckoosandbox.org/
# Litterbox: alternative cloud sandbox
CUCKOO_URL=
CUCKOO_API_KEY=
LITTERBOX_URL=
LITTERBOX_API_KEY=

# ── Email Alerts (Gmail SMTP) ────────────────────────────────────────────
# Generate App Password at: https://myaccount.google.com/apppasswords
# (requires 2FA enabled on your Google account)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SENDER=your-email@gmail.com
SMTP_APP_PASSWORD=
SMTP_RECIPIENT=soc-alerts@yourcompany.com
SMTP_ENABLED=0

# ── Database ─────────────────────────────────────────────────────────────
# Path to SQLite database file
SOC_DB_PATH=incidents.db

# ── API Security ─────────────────────────────────────────────────────────
# Generated random token for backend API authentication
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SOC_API_KEY=

# ── Threat Scoring Tuning ────────────────────────────────────────────────
# Minimum threat score to trigger auto-block (0-100)
# 90+ = only most severe threats auto-block
# 75  = moderate + severe threats auto-block
# 60  = more aggressive auto-blocking
SOC_AUTO_BLOCK_SCORE=90

# ── Feature Flags ────────────────────────────────────────────────────────
# Enable/disable optional detection engines
# Format: 0, false, or no = disabled; anything else = enabled
SOC_ENABLE_OLLAMA=1
SOC_ENABLE_REPORTS=1
